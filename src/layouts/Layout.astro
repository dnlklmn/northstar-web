---
interface Props {
  title?: string;
}
const { title = 'north star' } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  <style is:global>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg: #0a0a0a;
      --fg: #e8e8e8;
      --dim: #555;
      --mid: #999;
      --accent: #e8e8e8;
      --font: "Courier New", Courier, monospace;
      --measure: 62ch;
    }

    html {
      background: var(--bg);
      color: var(--fg);
      font-family: var(--font);
      font-size: 14px;
      line-height: 1.7;
      -webkit-font-smoothing: antialiased;
    }

    body {
      max-width: var(--measure);
      margin: 0 auto;
      padding: 4rem 2rem 8rem;
    }

    h1 {
      font-size: 13px;
      font-weight: normal;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--fg);
      margin-bottom: 4rem;
    }

    h2 {
      font-size: 13px;
      font-weight: normal;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--dim);
      margin-top: 4rem;
      margin-bottom: 1.5rem;
    }

    p {
      color: var(--fg);
      margin-bottom: 1.2rem;
      max-width: var(--measure);
    }

    p.dim {
      color: var(--mid);
    }

    em {
      font-style: normal;
      color: var(--mid);
    }

    strong {
      font-weight: bold;
      color: var(--fg);
    }

    hr {
      border: none;
      border-top: 1px solid #1e1e1e;
      margin: 3rem 0;
    }

    .lede {
      font-size: 16px;
      line-height: 1.6;
      color: var(--fg);
      margin-bottom: 2rem;
    }

    .services {
      list-style: none;
      margin-top: 1rem;
    }

    .services li {
      display: grid;
      grid-template-columns: 1fr;
      padding: 1.2rem 0;
      border-top: 1px solid #1e1e1e;
    }

    .services li:last-child {
      border-bottom: 1px solid #1e1e1e;
    }

    .services .service-name {
      color: var(--fg);
      margin-bottom: 0.3rem;
    }

    .services .service-desc {
      color: var(--mid);
      font-size: 13px;
    }

    .steps {
      list-style: none;
      counter-reset: steps;
      margin-top: 1rem;
    }

    .steps li {
      counter-increment: steps;
      display: grid;
      grid-template-columns: 2ch 1fr;
      gap: 1.5rem;
      padding: 0.8rem 0;
      border-top: 1px solid #1e1e1e;
      color: var(--mid);
      font-size: 13px;
    }

    .steps li:last-child { border-bottom: 1px solid #1e1e1e; }

    .steps li::before {
      content: counter(steps);
      color: var(--dim);
    }

    .steps li span {
      color: var(--fg);
    }

    .contact {
      margin-top: 4rem;
    }

    a {
      color: var(--fg);
      text-decoration: underline;
      text-underline-offset: 3px;
      text-decoration-color: var(--dim);
    }

    a:hover {
      text-decoration-color: var(--fg);
    }

    footer {
      margin-top: 6rem;
      color: var(--dim);
      font-size: 12px;
    }
  </style>
</head>
<body>
  <slot />
</body>
</html>
