---
import Layout from "./Layout.astro";

const { frontmatter } = Astro.props;
---

<Layout title={frontmatter.title}>
    <h1>{frontmatter.title}</h1>

    {Array.isArray(frontmatter.lede)
        ? frontmatter.lede.map((p: string) => <p class="lede">{p}</p>)
        : <p class="lede">{frontmatter.lede}</p>
    }
    {
        frontmatter.tagline &&
            (Array.isArray(frontmatter.tagline) ? (
                <div class="tagline">
                    {frontmatter.tagline.map((item: string, i: number) => (
                        <>
                            {i > 0 && <p class="dim tagline-arrow">↓</p>}
                            <p class="dim">{item}</p>
                        </>
                    ))}
                </div>
            ) : (
                <p class="dim">{frontmatter.tagline}</p>
            ))
    }
    {
        frontmatter.intro &&
            (Array.isArray(frontmatter.intro) ? (
                frontmatter.intro.map((p: string) => <p>{p}</p>)
            ) : (
                <p>{frontmatter.intro}</p>
            ))
    }

    {
        frontmatter.what_we_do && (
            <>
                <hr />
                <h2>What we do</h2>
                {frontmatter.what_we_do.map((p: string) => (
                    <p>{p}</p>
                ))}
            </>
        )
    }

    {
        frontmatter.services && (
            <>
                <hr />
                <h2>What you can expect</h2>
                <ul class="services">
                    {frontmatter.services.map(
                        (s: { name: string; desc: string }) => (
                            <li>
                                <span class="service-name">{s.name}</span>
                                <span class="service-desc">{s.desc}</span>
                            </li>
                        ),
                    )}
                </ul>
            </>
        )
    }

    {
        frontmatter.steps && (
            <>
                <hr />
                <h2>How an engagement works</h2>
                <ol class="steps">
                    {frontmatter.steps.map((step: string) => (
                        <li>
                            <span>{step}</span>
                        </li>
                    ))}
                </ol>
            </>
        )
    }

    {
        frontmatter.why_us && (
            <>
                <hr />
                <h2>Why work with us</h2>
                <ul class="services">
                    {frontmatter.why_us.map(
                        (s: { name: string; desc: string }) => (
                            <li>
                                <span class="service-name">{s.name}</span>
                                <span class="service-desc">{s.desc}</span>
                            </li>
                        ),
                    )}
                </ul>
            </>
        )
    }

    {
        frontmatter.contact && (
            <div class="contact">
                <p>
                    <a href={`mailto:${frontmatter.contact}`}>
                        {frontmatter.contact}
                    </a>
                </p>
            </div>
        )
    }

    <footer>
        <p>north star &mdash; 2026</p>
    </footer>
</Layout>
